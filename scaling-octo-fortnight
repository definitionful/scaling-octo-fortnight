local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local Config = {
    Enabled = false,
    ShowHitboxes = false,
    SizeMultiplier = 0,
    TargetPart = "HumanoidRootPart",
    HitboxColor = Color3.fromRGB(255, 0, 0), -- Default to Red
    TeamCheck = false
}

local originalStates = {}

-- Identify the executor
local executorName = type(identifyexecutor) == "function" and identifyexecutor() or "Unknown"

-- Only apply the metatable bypass if the executor is NOT Xeno
if not string.match(executorName, "Xeno") then
    local gameMeta = getrawmetatable(game)
    local oldIndex = gameMeta.__index

    setreadonly(gameMeta, false)

    gameMeta.__index = newcclosure(function(self, key)
        if not checkcaller() then
            if Config.Enabled or Config.ShowHitboxes then
                -- Intercept checks for Size, Material, Transparency, Color, and CanCollide
                if key == "Size" or key == "Material" or key == "Transparency" or key == "Color" or key == "CanCollide" then
                    if typeof(self) == "Instance" and self.Name == Config.TargetPart then
                        local cachedData = originalStates[self]
                        if cachedData then
                            if key == "Size" then 
                                return cachedData.Size 
                            elseif key == "Material" then 
                                return cachedData.Material 
                            elseif key == "Transparency" then
                                return cachedData.Transparency
                            elseif key == "Color" then
                                return cachedData.Color
                            elseif key == "CanCollide" then
                                return cachedData.CanCollide
                            end
                        end
                    end
                end
            end
        end
        
        return oldIndex(self, key)
    end)

    setreadonly(gameMeta, true)
end

-- Cleanup when players leave
Players.PlayerRemoving:Connect(function(player)
    for part, _ in pairs(originalStates) do
        if not part.Parent or (player.Character and part:IsDescendantOf(player.Character)) then
            originalStates[part] = nil
        end
    end
end)

local function updateHitboxes()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            
            -- Determine if we should ignore this player due to Team Check
            local isTeammate = Config.TeamCheck and player.Team == LocalPlayer.Team

            local humanoid = player.Character:FindFirstChild("Humanoid")
            local targetPart = player.Character:FindFirstChild(Config.TargetPart)
            
            -- Cache the target part if it exists and hasn't been cached
            if targetPart and targetPart:IsA("BasePart") and humanoid and humanoid.Health > 0 then
                if not originalStates[targetPart] then
                    originalStates[targetPart] = {
                        Size = targetPart.Size,
                        Material = targetPart.Material,
                        Transparency = targetPart.Transparency,
                        Color = targetPart.Color,
                        CanCollide = targetPart.CanCollide
                    }
                end
            end

            -- Iterate through ALL cached parts for this character to update or revert them
            for part, cached in pairs(originalStates) do
                if part:IsDescendantOf(player.Character) then
                    
                    -- Check if this specific part is the current target and player is valid/enemy
                    local isValidTarget = (part.Name == Config.TargetPart) and (not isTeammate) and (humanoid and humanoid.Health > 0)

                    -- Handle Size & Collision Toggle
                    if Config.Enabled and isValidTarget then
                        local scale = (Config.SizeMultiplier == 0) and 1 or Config.SizeMultiplier
                        part.Size = Vector3.new(cached.Size.X * scale, cached.Size.Y * scale, cached.Size.Z * scale)
                        part.CanCollide = false -- Forces collision off for Head/HRP to prevent flinging
                    else
                        part.Size = cached.Size
                        part.CanCollide = cached.CanCollide -- Safely reverts to original state
                    end

                    -- Handle Visuals Toggle
                    if Config.ShowHitboxes and isValidTarget then
                        part.Material = Enum.Material.ForceField
                        part.Transparency = 0 
                        part.Color = Config.HitboxColor
                    else
                        part.Material = cached.Material
                        part.Transparency = cached.Transparency
                        part.Color = cached.Color
                    end
                end
            end
            
        end
    end
end

task.spawn(function()
    while task.wait(0.5) do
        updateHitboxes()
    end
end)

