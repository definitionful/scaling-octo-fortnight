local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local Config = {
    Enabled = false,
    ShowHitboxes = false,
    SizeMultiplier = 0
}

local originalStates = {}

-- Identify the executor
local executorName = type(identifyexecutor) == "function" and identifyexecutor() or "Unknown"

-- Only apply the metatable bypass if the executor is NOT Xeno
if not string.match(executorName, "Xeno") then
    local gameMeta = getrawmetatable(game)
    local oldIndex = gameMeta.__index

    setreadonly(gameMeta, false)

    gameMeta.__index = newcclosure(function(self, key)
        if not checkcaller() then
            if Config.Enabled or Config.ShowHitboxes then
                if key == "Size" or key == "Material" or key == "Transparency" then
                    if typeof(self) == "Instance" and self.Name == "HumanoidRootPart" then
                        local cachedData = originalStates[self]
                        if cachedData then
                            if key == "Size" then 
                                return cachedData.Size 
                            elseif key == "Material" then 
                                return cachedData.Material 
                            elseif key == "Transparency" then
                                return cachedData.Transparency
                            end
                        end
                    end
                end
            end
        end
        
        return oldIndex(self, key)
    end)

    setreadonly(gameMeta, true)
end

Players.PlayerRemoving:Connect(function(player)
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        originalStates[player.Character.HumanoidRootPart] = nil
    end
end)

local function updateHitboxes()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = player.Character:FindFirstChild("Humanoid")
            
            if hrp and hrp:IsA("BasePart") and humanoid and humanoid.Health > 0 then
                
                if not originalStates[hrp] then
                    originalStates[hrp] = {
                        Size = hrp.Size,
                        Material = hrp.Material,
                        Transparency = hrp.Transparency
                    }
                end

                local cached = originalStates[hrp]
                
                if Config.Enabled then
                    local scale = (Config.SizeMultiplier == 0) and 1 or Config.SizeMultiplier
                    hrp.Size = Vector3.new(cached.Size.X * scale, cached.Size.Y * scale, cached.Size.Z * scale)
                    hrp.CanCollide = false 
                else
                    hrp.Size = cached.Size
                    hrp.CanCollide = true
                end

                if Config.ShowHitboxes then
                    hrp.Material = Enum.Material.ForceField
                    hrp.Transparency = 0.5
                else
                    hrp.Material = cached.Material
                    hrp.Transparency = cached.Transparency
                end
                
            end
        end
    end
end

task.spawn(function()
    while task.wait(0.5) do
        updateHitboxes()
    end
end)

local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "Hitbox Expander",
    SubTitle = "Metatable Bypass",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = true, 
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl 
})

local Tabs = {
    Main = Window:AddTab({ Title = "Combat", Icon = "swords" })
}

local HitboxToggle = Tabs.Main:AddToggle("HitboxToggle", {
    Title = "Enable Hitbox Expander", 
    Default = false,
    Callback = function(state)
        Config.Enabled = state
        updateHitboxes() 
    end 
})

local VisualToggle = Tabs.Main:AddToggle("VisualToggle", {
    Title = "Show Hitboxes (Forcefield)",
    Default = false,
    Callback = function(state)
        Config.ShowHitboxes = state
        updateHitboxes()
    end
})

local HitboxSlider = Tabs.Main:AddSlider("HitboxSlider", {
    Title = "Hitbox Size Multiplier",
    Default = 0,
    Min = 0,
    Max = 10,
    Rounding = 1,
    Callback = function(Value)
        Config.SizeMultiplier = Value
        updateHitboxes() 
    end
})

Window:SelectTab(1)
